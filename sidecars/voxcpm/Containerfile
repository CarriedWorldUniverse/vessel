FROM docker.io/vllm/vllm-openai:nightly

RUN apt-get update \
  && apt-get install -y --no-install-recommends git \
  && rm -rf /var/lib/apt/lists/* \
  && python3 -m pip install --upgrade pip \
  && python3 -m pip install \
    'git+https://github.com/nexus-cw/VoxCPM' \
    fastapi \
    uvicorn \
    soundfile

COPY server.py /opt/vessel/voxcpm/server.py

ENV VESSEL_VOXCPM_LISTEN_PORT=8000
EXPOSE 8000

CMD ["python3", "/opt/vessel/voxcpm/server.py", "--host", "0.0.0.0", "--port", "8000"]

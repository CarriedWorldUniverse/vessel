{
  "name": "vessel",
  "version": "0.1.0",
  "description": "A desktop overlay that gives your LLM aspects a face and a voice",
  "author": "Carried World Universe",
  "main": "src/main/main.js",
  "scripts": {
    "build:speech-helper": "swiftc native/macos/VesselSpeech.swift -o native/macos/VesselSpeech",
    "start": "npm run build:speech-helper && electron .",
    "dev": "npm run build:speech-helper && electron . --dev",
    "check": "node --check src/main/main.js && node --check src/main/preload.js && for f in src/renderer/*.js; do node --check \"$f\"; done",
    "probe:nexus": "node scripts/nexus-probe.js",
    "sign:mac:adhoc": "find dist -maxdepth 2 -name '*.app' -exec codesign --force --deep --sign - {} \\;",
    "build:mac": "npm run build:speech-helper && electron-builder --mac --dir && npm run sign:mac:adhoc",
    "dist:mac": "npm run build:mac"
  },
  "dependencies": {
    "three": "^0.176.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1"
  },
  "license": "Apache-2.0",
  "build": {
    "appId": "universe.carriedworld.vessel",
    "productName": "Vessel",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "src/**/*",
      "sidecars/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "native/macos/VesselSpeech",
        "to": "native/macos/VesselSpeech"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Vessel records your voice when you use Dictate.",
        "NSSpeechRecognitionUsageDescription": "Vessel uses Apple Speech to transcribe dictated prompts."
      },
      "target": [
        "dir",
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "sign": false
    }
  }
}
